#!/bin/sh
# Hook commit-msg : impose la convention de message du projet.
# Préfixes valides : feat: fix: chore: docs: refactor: test:  (ou un merge).
msg=$(head -1 "$1")

case "$msg" in
  feat:*|fix:*|chore:*|docs:*|refactor:*|test:*|Merge\ *|"Revert "*)
    exit 0 ;;
  *)
    echo "✗ Message de commit invalide :"
    echo "    « $msg »"
    echo "  Préfixe attendu : feat: | fix: | chore: | docs: | refactor: | test:"
    echo "  Exemple : feat: ajoute la coloration des termes du dictionnaire"
    exit 1 ;;
esac
